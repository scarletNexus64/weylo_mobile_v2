<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Configuration pour le développement : autoriser HTTP cleartext pour localhost et IPs locales -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Localhost -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- Android Emulator -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Plages IP privées (RFC 1918) -->
        <!-- IP de développement -->
        <domain includeSubdomains="true">nonhedonic-slung-aura.ngrok-free.dev</domain>
        <domain includeSubdomains="true">192.168.100.30</domain>
    </domain-config>

    <!-- ATTENTION: En production, utilisez HTTPS et supprimez cette configuration -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
